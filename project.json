{
  "name": "edgework-sdk",
  "sourceRoot": "packages/edgework-sdk/src",
  "projectType": "library",
  "tags": ["scope:shared", "type:lib"],
  "targets": {
    "build": {
      "executor": "a0:run-commands",
      "dependsOn": ["build:prep", "build:js", "build:dts"],
      "outputs": ["{projectRoot}/dist"]
    },
    "build:prep": {
      "executor": "a0:run-commands",
      "options": {
        "cwd": "packages/edgework-sdk",
        "command": "bun run build:prep"
      }
    },
    "build:js": {
      "executor": "a0:run-commands",
      "dependsOn": ["build:prep"],
      "options": {
        "cwd": "packages/edgework-sdk",
        "command": "bun run build:js"
      }
    },
    "build:dts": {
      "executor": "a0:run-commands",
      "dependsOn": ["build:prep"],
      "options": {
        "cwd": "packages/edgework-sdk",
        "command": "bun run build:dts"
      }
    },
    "typecheck": {
      "executor": "a0:run-commands",
      "dependsOn": ["build:dts"],
      "options": {
        "cwd": "packages/edgework-sdk",
        "command": "bun run typecheck"
      }
    },
    "test": {
      "executor": "a0:run-commands",
      "options": {
        "cwd": "packages/edgework-sdk",
        "command": "bun ../../scripts/aeon-test.ts . --preload ../../bun.preload.ts"
      }
    },
    "lint": {
      "executor": "a0:eslint",
      "options": {
        "lintFilePatterns": [
          "packages/edgework-sdk/src/**/*.{ts,tsx}",
          "!packages/edgework-sdk/src/**/*.gen.ts"
        ]
      }
    },
    "dev": {
      "executor": "a0:run-commands",
      "options": {
        "cwd": "packages/edgework-sdk",
        "command": "bun run dev"
      }
    }
  }
}
