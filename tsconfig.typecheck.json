{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": "../..",
    "paths": {
      "@emotions-app/shared-ui/*": ["../../shared-ui/*"],
      "@emotions-app/shared-utils/edge/forgo-logs-types": [
        "../../shared-utils/src/edge/forgo-logs-types.ts"
      ]
    }
  },
  "include": [
    "src/**/*",
    "../../shared-ui/types/agent-website.ts",
    "../../shared-ui/src/types/agent-website.ts",
    "../../shared-utils/src/edge/forgo-logs-types.ts"
  ],
  "exclude": ["node_modules", "dist", "../../shared-ui/types/**/*.test.ts"]
}
