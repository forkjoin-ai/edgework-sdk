{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "incremental": false,
    "paths": {
      "@emotions-app/shared-ui/types/agent-website": ["./dts-shims.d.ts"],
      "@emotions-app/shared-utils/edge/forgo-logs-types": ["./dts-shims.d.ts"]
    },
    "noEmit": false
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "dts-shims.d.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.js",
    "src/**/*.js.map",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/__tests__/**"
  ]
}
